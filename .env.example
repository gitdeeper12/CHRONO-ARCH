# CHRONO-ARCH v1.0.0 Environment Configuration

# Core Dynamics
CA_DT=0.01
CA_T_MAX=1000.0
CA_N_DIMENSIONS=6
CA_N_CIVILIZATIONS=10

# Collapse Detection
CA_COLLAPSE_THRESHOLD=0.35
CA_EARLY_WARNING_WINDOW=50

# Environmental Coupling
CA_ENV_COUPLING_ENABLED=true
CA_ENV_DATA_PATH=./data/paleoclimate/

# Graph Dynamics
CA_GRAPH_DYNAMICS_ENABLED=true
CA_GRAPH_UPDATE_RULE=coevolution

# Probabilistic Layer
CA_FOKKER_PLANCK_ENABLED=true
CA_SDE_DIFFUSION_COEFFICIENT=0.1

# Causal Inference
CA_CAUSAL_GRAPH_LEARNING=constraint_based
CA_COUNTERFACTUAL_SAMPLES=1000

# Output
CA_OUTPUT_DIR=./output/
CA_LOG_LEVEL=INFO
